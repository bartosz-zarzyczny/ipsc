{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "competitor.json",
  "title": "Competitor",
  "description": "A single competitor's result within a match, as stored in matches.data_json and returned by the match API.",
  "type": "object",
  "required": [
    "rank", "comp_id", "firstname", "lastname", "name",
    "division", "div_id", "category", "female", "squad",
    "is_disq", "total_points", "total_points_overall",
    "total_points_in_division", "total_time", "overall_hf",
    "pct", "stage_scores"
  ],
  "additionalProperties": false,
  "properties": {
    "rank": {
      "type": "integer",
      "description": "Overall rank within the match (1-based).",
      "minimum": 1
    },
    "comp_id": {
      "type": "string",
      "description": "WinMSS competitor identifier."
    },
    "firstname": {
      "type": "string"
    },
    "lastname": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "description": "Concatenated display name: '{lastname} {firstname}'."
    },
    "division": {
      "type": "string",
      "description": "Division name as imported from WinMSS (may be remapped by division_mappings)."
    },
    "div_id": {
      "type": "string",
      "description": "WinMSS internal division identifier."
    },
    "category": {
      "type": "string",
      "description": "Competitor category (e.g. Junior, Senior, Superunior). Empty string if default."
    },
    "female": {
      "type": "boolean",
      "description": "True when the competitor competes in the Ladies category."
    },
    "squad": {
      "type": "string",
      "description": "Squad/group assignment from WinMSS. May be empty."
    },
    "is_disq": {
      "type": "boolean",
      "description": "True when the competitor was disqualified."
    },
    "total_points": {
      "type": "number",
      "description": "Raw points scored across all stages."
    },
    "total_points_overall": {
      "type": "number",
      "description": "Points used for overall ranking (may include multiplier)."
    },
    "total_points_in_division": {
      "type": "number",
      "description": "Points used for division ranking."
    },
    "total_time": {
      "type": "number",
      "description": "Total time in seconds, rounded to 2 decimal places.",
      "minimum": 0
    },
    "overall_hf": {
      "type": "number",
      "description": "Overall hit-factor (points / time), rounded to 4 decimal places.",
      "minimum": 0
    },
    "pct": {
      "type": "number",
      "description": "Percentage of best result in division (0–100), rounded to 2 decimal places.",
      "minimum": 0,
      "maximum": 100
    },
    "stage_scores": {
      "type": "array",
      "description": "Per-stage score objects in stage order. null means competitor did not attempt the stage.",
      "items": {
        "oneOf": [
          {"type": "null"},
          {"$ref": "#/$defs/StageScore"}
        ]
      }
    }
  },
  "$defs": {
    "StageScore": {
      "type": "object",
      "required": ["pts", "time", "hf", "A", "B", "C", "D", "M", "PE", "NS", "disq"],
      "additionalProperties": false,
      "properties": {
        "pts":  {"type": "number", "description": "Points scored on this stage."},
        "time": {"type": "number", "description": "Stage time in seconds.", "minimum": 0},
        "hf":   {"type": "number", "description": "Hit-factor for this stage.", "minimum": 0},
        "A":    {"type": "integer", "description": "Alpha hits.", "minimum": 0},
        "B":    {"type": "integer", "description": "Bravo hits.", "minimum": 0},
        "C":    {"type": "integer", "description": "Charlie hits.", "minimum": 0},
        "D":    {"type": "integer", "description": "Delta hits.", "minimum": 0},
        "M":    {"type": "integer", "description": "Misses.", "minimum": 0},
        "PE":   {"type": "integer", "description": "Procedural errors.", "minimum": 0},
        "NS":   {"type": "integer", "description": "No-shoots hit.", "minimum": 0},
        "disq": {"type": "boolean", "description": "True when competitor was disqualified on this stage."}
      }
    }
  }
}
