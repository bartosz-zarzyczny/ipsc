{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "match.json",
  "title": "MatchResult",
  "description": "Full match result — the canonical structure produced by _prepare() and stored in matches.data_json. Also returned verbatim by GET /api/matches/{id}.",
  "type": "object",
  "required": ["match", "stages", "competitors"],
  "additionalProperties": false,
  "properties": {
    "match": {
      "type": "object",
      "required": ["name", "date", "level"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer",
          "description": "Database row id. Added to the response after saving; not present in the raw blob.",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "description": "Match name extracted from WinMSS MatchName field.",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "description": "Match date in YYYY-MM-DD format.",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "level": {
          "type": "integer",
          "description": "IPSC match level (1–5) parsed from the match name or MatchLevel field.",
          "minimum": 1,
          "maximum": 5
        },
        "multiplier": {
          "type": "number",
          "description": "Ranking score multiplier applied when match is part of a ranking. Injected by get_match_with_multiplier(); not stored in data_json.",
          "minimum": 0,
          "default": 1.0
        }
      }
    },
    "stages": {
      "type": "array",
      "description": "Ordered list of stages in the match.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "max_points", "max_hf_by_div"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "description": "WinMSS StageId.",
            "oneOf": [
              {"type": "string"},
              {"type": "integer"}
            ]
          },
          "name": {
            "type": "string",
            "description": "Stage name.",
            "minLength": 1
          },
          "max_points": {
            "type": "integer",
            "description": "Maximum possible points on this stage.",
            "minimum": 0
          },
          "max_hf_by_div": {
            "type": "object",
            "description": "Per-division maximum hit-factor achieved on this stage. Keys are division names.",
            "additionalProperties": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "competitors": {
      "type": "array",
      "description": "All competitors sorted by rank.",
      "items": {
        "$ref": "competitor.json"
      }
    }
  }
}
